# =============================================================================
# Pi Temperature Alerter - Configuration
# =============================================================================
# Copy this file to .env and adjust values to suit your environment.

# -----------------------------------------------------------------------------
# SMTP Configuration
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Sender address (appears in the From field)
EMAIL_FROM=your-email@gmail.com

# -----------------------------------------------------------------------------
# Alert Recipients
# -----------------------------------------------------------------------------
# Comma-separated email addresses per threshold level
EMAIL_RECIPIENTS_WARNING=you@example.com
EMAIL_RECIPIENTS_CRITICAL=you@example.com,team@example.com
EMAIL_RECIPIENTS_EMERGENCY=you@example.com,team@example.com,oncall@example.com

# -----------------------------------------------------------------------------
# Temperature Thresholds (degrees Celsius)
# -----------------------------------------------------------------------------
TEMP_WARNING=60.0
TEMP_CRITICAL=70.0
TEMP_EMERGENCY=80.0

# Hysteresis: temperature must drop this many degrees below a threshold
# before the alert state is cleared (prevents flapping)
TEMP_HYSTERESIS=3.0

# -----------------------------------------------------------------------------
# Monitoring Settings
# -----------------------------------------------------------------------------
# Polling interval in seconds
POLL_INTERVAL=30

# Cooldown period in seconds between repeated alerts of the same level
ALERT_COOLDOWN=300

# Enable recovery notifications when temperature returns to normal
RECOVERY_NOTIFICATIONS=true

# Rate-of-change threshold in degrees C per minute (0 = disabled)
# Alerts if temperature rises faster than this rate
RATE_OF_CHANGE_THRESHOLD=0

# Escalation timeout in seconds (0 = disabled)
# If an alert remains at the same level for this long, auto-escalate
ESCALATION_TIMEOUT=0

# Daily digest email with min/max/avg temperatures
DAILY_DIGEST_ENABLED=false
DAILY_DIGEST_HOUR=7

# -----------------------------------------------------------------------------
# Sensors
# -----------------------------------------------------------------------------
# Enable CPU temperature monitoring (via vcgencmd or thermal_zone)
SENSOR_CPU_ENABLED=true

# Enable GPU temperature monitoring (via vcgencmd)
SENSOR_GPU_ENABLED=true

# Enable DS18B20 one-wire sensors (requires wiring and kernel module)
SENSOR_DS18B20_ENABLED=false

# DS18B20 device directory (default for one-wire on Pi)
DS18B20_BASE_DIR=/sys/bus/w1/devices

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Maximum log file size in MB before rotation
LOG_MAX_SIZE_MB=10

# Number of rotated log files to retain
LOG_BACKUP_COUNT=5

# Enable CSV temperature history logging
CSV_LOGGING_ENABLED=true

# Number of days to retain CSV history files before pruning
CSV_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Dashboard
# -----------------------------------------------------------------------------
# Enable the web dashboard
DASHBOARD_ENABLED=true

# Host and port for the Flask dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000

# Optional basic authentication for the dashboard
DASHBOARD_AUTH_ENABLED=false
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=

# Individually toggle dashboard endpoints on/off
ENDPOINT_API_ENABLED=true
ENDPOINT_HEALTH_ENABLED=true
ENDPOINT_METRICS_ENABLED=true

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Enable database persistence (in addition to CSV)
DATABASE_ENABLED=true

# Connection URL - supports SQLite, MySQL, and PostgreSQL
# SQLite (default):  sqlite:///data/pi_temp_alerter.db
# MySQL:             mysql+pymysql://user:pass@host:3306/dbname
# PostgreSQL:        postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///data/pi_temp_alerter.db

# -----------------------------------------------------------------------------
# Notifications (Optional - in addition to email)
# -----------------------------------------------------------------------------
# Generic webhook (sends JSON POST on alert/recovery)
WEBHOOK_ENABLED=false
WEBHOOK_URL=
# Set to false only for internal self-signed endpoints
WEBHOOK_VERIFY_SSL=true

# Telegram Bot notifications
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Pushover push notifications
PUSHOVER_ENABLED=false
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# MQTT publishing (for Home Assistant / IoT integration)
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
# Enable TLS encryption (use port 8883 with this enabled)
MQTT_TLS=false
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=pi-temp-alerter
MQTT_TOPIC_PREFIX=pi-temp-alerter

# -----------------------------------------------------------------------------
# Advanced
# -----------------------------------------------------------------------------
# Dry-run mode: log alerts but do not send emails
DRY_RUN=false

# Low-write mode: minimises SD card writes for longevity.
# When enabled, this automatically:
#   - Disables CSV logging (database is used instead)
#   - Enforces a minimum 60-second poll interval
#   - Reduces log verbosity to WARNING level
# Recommended for SD card deployments that run 24/7.
LOW_WRITE_MODE=false

# -----------------------------------------------------------------------------
# Fan Control (Optional)
# -----------------------------------------------------------------------------
# Enable GPIO-based fan control
FAN_CONTROL_ENABLED=false

# BCM GPIO pin connected to the fan transistor/relay
FAN_GPIO_PIN=14

# Temperature at which the fan turns on
FAN_ON_THRESHOLD=55.0

# Temperature at which the fan turns off (provides hysteresis)
FAN_OFF_THRESHOLD=45.0

# -----------------------------------------------------------------------------
# External Service Collectors (Optional)
# -----------------------------------------------------------------------------
# These collectors auto-detect co-hosted services and publish their stats
# via MQTT alongside temperature data. Requires MQTT_ENABLED=true.
#
# Behaviour:
#   - Not set (default): Auto-detect. If the service is found, publish stats.
#   - true: Force enabled (errors logged if service not found)
#   - false: Explicitly disabled (never attempt collection)

# FlightRadar24 feed (fr24feed) statistics
# Auto-detects via fr24feed's local HTTP endpoint (port 8754)
#COLLECTOR_FR24_ENABLED=

# readsb ADS-B decoder statistics
# Auto-detects via JSON stats files in the run directory
#COLLECTOR_READSB_ENABLED=
COLLECTOR_READSB_STATS_DIR=/run/readsb

# -----------------------------------------------------------------------------
# Per-Sensor Threshold Overrides (Optional)
# -----------------------------------------------------------------------------
# Override thresholds for specific sensors. Format:
#   TEMP_WARNING_<SENSOR_NAME>=<value>
#   TEMP_CRITICAL_<SENSOR_NAME>=<value>
#   TEMP_EMERGENCY_<SENSOR_NAME>=<value>
#
# Sensor names use uppercase with hyphens replaced by underscores.
# Examples:
#   TEMP_WARNING_CPU=65
#   TEMP_CRITICAL_GPU=75
#   TEMP_WARNING_DS18B20_28_0000XXXX=25
#   TEMP_CRITICAL_DS18B20_28_0000XXXX=35
